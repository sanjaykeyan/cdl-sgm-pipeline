# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to git — it is already in .gitignore.
#
# On Streamlit Community Cloud, paste these key-value pairs directly into
# App settings → Secrets (no file needed).

QUALTRICS_API_TOKEN = "your_api_token_here"
QUALTRICS_SURVEY_ID = "SV_xxxxxxxxxxxxxxx"
QUALTRICS_BASE_URL  = "https://yul1.qualtrics.com"
